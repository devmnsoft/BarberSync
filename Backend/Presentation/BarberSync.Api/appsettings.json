{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Redis": {
    "Enabled": false,
    "ConnectionString": ""
  },
  "Messaging": {
    "Enabled": false,
    "Provider": "InMemory",
    "ConnectionString": ""
  }
}
