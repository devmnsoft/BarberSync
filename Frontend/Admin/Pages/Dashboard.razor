@page "/dashboard"

<h3>BarberSync Admin Dashboard 3.0</h3>
<p>Widgets interativos com foco em ocupação, estoque, IA, fidelidade e alertas inteligentes.</p>

<div style="display:grid;grid-template-columns:repeat(3,minmax(220px,1fr));gap:12px;">
    <section style="padding:12px;border:1px solid #ddd;border-radius:8px;">
        <h4>Ocupação em tempo real</h4>
        <strong>81%</strong>
        <p>2 profissionais em sobrecarga.</p>
    </section>
    <section style="padding:12px;border:1px solid #ddd;border-radius:8px;">
        <h4>Estoque crítico</h4>
        <strong>3 itens</strong>
        <p>Alertas automáticos para reposição enviados.</p>
    </section>
    <section style="padding:12px;border:1px solid #ddd;border-radius:8px;">
        <h4>Upsell por IA</h4>
        <strong>37%</strong>
        <p>Sugestões de serviços adicionais em alta.</p>
    </section>
    <section style="padding:12px;border:1px solid #ddd;border-radius:8px;">
        <h4>Clientes VIP</h4>
        <strong>124</strong>
        <p>Cashback e pontos sincronizados com mobile e totem.</p>
    </section>
    <section style="padding:12px;border:1px solid #ddd;border-radius:8px;">
        <h4>Agendamento preditivo</h4>
        <strong>+18%</strong>
        <p>Eficiência após otimização automática de janelas.</p>
    </section>
    <section style="padding:12px;border:1px solid #ddd;border-radius:8px;">
        <h4>Alertas inteligentes</h4>
        <strong>7 ativos</strong>
        <p>Triggers para atrasos, lotação e promoções.</p>
    </section>
</div>
