@{
    ViewData["Title"] = "Agendamentos";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<section class="page-header">
    <div>
        <h1 class="page-title">Agendamentos</h1>
        <p class="page-subtitle">Timeline operacional do dia. Dados carregados por proxy MVC <strong>/AdminApi/appointments</strong> com fallback demo.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-light" data-admin-refresh="Appointments">Atualizar</button>
        <button class="btn btn-primary" data-admin-new="Appointments">Novo Agendamento</button>
    </div>
</section>
<div class="alert alert-warning d-none" id="AppointmentsFallback">API indisponível: modo demonstração seguro ativo.</div>
<section class="admin-module-grid" id="AppointmentsCards">
    <article class="kpi-card"><div class="kpi-icon">💈</div><div><p class="kpi-label">Carregando</p><strong class="kpi-value">...</strong><span class="kpi-variation">BarberSync</span></div></article>
</section>
<section class="enterprise-demo-grid"><article class="enterprise-card wide"><h3>Timeline por horário</h3><div class="kanban-demo"><div class="kanban-col"><strong>Rafael</strong><div class="kanban-card">10:30 Lucas • Confirmado</div><div class="kanban-card">18:30 André • Agendado</div></div><div class="kanban-col"><strong>Camila</strong><div class="kanban-card">14:00 Marina • Check-in</div></div><div class="kanban-col"><strong>Lista de espera</strong><div class="kanban-card">João • Corte rápido</div></div></div><small>Arraste disponível na versão Pro.</small></article><article class="enterprise-card"><h3>Status guiado</h3><div class="tag-list"><span class="tag">Confirmar</span><span class="tag">Check-in</span><span class="tag">Iniciar</span><span class="tag">Finalizar</span><span class="tag">Cancelar</span></div></article></section>
<!-- Demo Experience 3.0 injected -->
<section class="enterprise-demo-grid">
  <article class="enterprise-card wide"><h3>Novo agendamento rápido</h3><p>Busca cliente, serviço, profissional e horários sugeridos. O fluxo Confirmar → Check-in → Iniciar → Finalizar → Abrir comanda atualiza Operations e Dashboard.</p><div class="quick-actions-grid"><button class="btn btn-primary" data-flow-quick-appointment>Novo agendamento rápido</button><a class="btn btn-light" href="/Admin/Operations">Ver status na Operação</a></div><div class="tag-list"><span class="tag">10:30</span><span class="tag">14:00</span><span class="tag">15:30</span><span class="tag">18:30</span></div></article>
</section>
<section class="panel module-panel">
    <div class="panel-header">
        <div><h3>Registros operacionais</h3><p>CRUD demonstrável com modais, toasts e fallback controlado.</p></div>
        <span class="badge badge-info">/AdminApi/appointments</span>
    </div>
    <div class="table-responsive">
        <table class="table admin-table"><thead><tr><th>Nome</th><th>Detalhe</th><th>Status</th><th>Ações</th></tr></thead><tbody id="AppointmentsRows"><tr><td colspan="4">Carregando...</td></tr></tbody></table>
    </div>
</section>
<div class="admin-modal-backdrop" id="AppointmentsModal" hidden>
    <form class="admin-modal" data-admin-form="Appointments">
        <div class="modal-header"><h3>Novo/editar Agendamento</h3><button type="button" class="modal-close" data-admin-close="Appointments">×</button></div>
        <label>Nome<input name="name" required placeholder="Nome" /></label>
        <label>Status<select name="status"><option>Ativo</option><option>Em atendimento</option><option>Pendente</option></select></label>
        <label>Observação<input name="notes" placeholder="Observação demo" /></label>
        <div class="modal-actions"><button type="button" class="btn btn-light" data-admin-close="Appointments">Cancelar</button><button class="btn btn-primary" type="submit">Salvar</button></div>
    </form>
</div>
@section Scripts {<script>window.renderAdminCrudPage && window.renderAdminCrudPage('Appointments')</script>}
