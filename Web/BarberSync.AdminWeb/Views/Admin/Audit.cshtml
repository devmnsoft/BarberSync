@{ ViewData["Title"] = "Auditoria e Logs"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="saas7-hero" data-audit-page><div><span class="badge">Sistema > Auditoria</span><h1>Auditoria e logs visuais</h1><p>Eventos do EventBus, ações de usuário, cadastros, agenda, comandas pagas, estoque, campanhas, Copilot, Totem e acessos demo.</p></div><div class="saas7-actions"><button class="btn btn-light" data-export-audit>Exportar mock</button><button class="btn btn-secondary" data-clear-audit>Limpar logs demo</button></div></section>
<section class="saas7-card full"><div class="saas7-toolbar"><select data-audit-module><option value="">Todos módulos</option><option>Configurações</option><option>Totem</option><option>Marketing</option><option>PDV</option><option>Estoque</option></select><select data-audit-severity><option value="">Todas severidades</option><option value="success">Sucesso</option><option value="info">Info</option><option value="warning">Atenção</option><option value="danger">Crítico</option></select><input type="date"><input type="date"></div><div style="margin-top:16px" data-audit-list></div></section>
