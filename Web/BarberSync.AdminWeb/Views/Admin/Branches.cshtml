@{ ViewData["Title"] = "Multiunidade / Franquias"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="saas7-hero" data-branches-page><div><span class="badge">Gestão > Unidades</span><h1>Multiunidade e franquias</h1><p>Comparativo executivo entre unidades, receita, agendamentos, ticket médio, avaliações, ocupação, profissionais e estoque crítico.</p></div><button class="btn btn-gold" form="BranchForm">Criar unidade</button></section>
<section class="saas7-grid"><article class="saas7-card wide"><h2>Ranking e comparativo</h2><div class="saas7-chart" data-branches-chart></div><table class="saas7-table"><thead><tr><th>Ranking</th><th>Unidade</th><th>Receita</th><th>Agendamentos</th><th>Ticket</th><th>Avaliação</th><th>Ocupação</th><th>Estoque crítico</th><th>Ações</th></tr></thead><tbody data-branches-rows></tbody></table></article><article class="saas7-card"><h2>Nova unidade demo</h2><form id="BranchForm" class="saas7-form" data-branch-form><label class="full">Nome da unidade<input name="name" required placeholder="BarberSync Nova Unidade"></label><label class="full">Status<select><option>Ativa</option><option>Implantação</option><option>Pausada</option></select></label><p>Ao criar, a unidade entra com indicadores iniciais e aparece no comparativo.</p></form></article></section>
