@{
    ViewData["Title"] = "Campanhas";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<section class="page-header">
    <div>
        <h1 class="page-title">Campanhas</h1>
        <p class="page-subtitle">CRM, canais e conversão. Dados carregados por proxy MVC <strong>/AdminApi/campaigns</strong> com fallback demo.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-light" data-admin-refresh="Campaigns">Atualizar</button>
        <button class="btn btn-primary" data-admin-new="Campaigns">Novo Campanha</button>
    </div>
</section>
<div class="alert alert-warning d-none" id="CampaignsFallback">API indisponível: modo demonstração seguro ativo.</div>
<section class="admin-module-grid" id="CampaignsCards">
    <article class="kpi-card"><div class="kpi-icon">💈</div><div><p class="kpi-label">Carregando</p><strong class="kpi-value">...</strong><span class="kpi-variation">BarberSync</span></div></article>
</section>
<section class="enterprise-demo-grid"><article class="enterprise-card wide"><h3>Jornada da campanha</h3><div class="timeline-demo"><div>Segmentar público-alvo</div><div>Enviar WhatsApp</div><div>Gerar cupom</div><div>Medir retorno</div></div></article><article class="enterprise-card"><h3>Resultado mock</h3><strong>18 reativações</strong><p>ROI estimado 4,2x.</p></article></section>
<section class="panel module-panel">
    <div class="panel-header">
        <div><h3>Registros operacionais</h3><p>CRUD demonstrável com modais, toasts e fallback controlado.</p></div>
        <span class="badge badge-info">/AdminApi/campaigns</span>
    </div>
    <div class="table-responsive">
        <table class="table admin-table"><thead><tr><th>Nome</th><th>Detalhe</th><th>Status</th><th>Ações</th></tr></thead><tbody id="CampaignsRows"><tr><td colspan="4">Carregando...</td></tr></tbody></table>
    </div>
</section>
<div class="admin-modal-backdrop" id="CampaignsModal" hidden>
    <form class="admin-modal" data-admin-form="Campaigns">
        <div class="modal-header"><h3>Novo/editar Campanha</h3><button type="button" class="modal-close" data-admin-close="Campaigns">×</button></div>
        <label>Nome<input name="name" required placeholder="Nome" /></label>
        <label>Status<select name="status"><option>Ativo</option><option>Em atendimento</option><option>Pendente</option></select></label>
        <label>Observação<input name="notes" placeholder="Observação demo" /></label>
        <div class="modal-actions"><button type="button" class="btn btn-light" data-admin-close="Campaigns">Cancelar</button><button class="btn btn-primary" type="submit">Salvar</button></div>
    </form>
</div>
@section Scripts {<script>window.renderAdminCrudPage && window.renderAdminCrudPage('Campaigns')</script>}
