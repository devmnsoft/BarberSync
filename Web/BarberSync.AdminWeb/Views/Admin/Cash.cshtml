@{ ViewData["Title"] = "Caixa"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="page-header"><div><h1 class="page-title">Caixa operacional</h1><p class="page-subtitle">Abertura, fechamento, sangria, suprimento, entradas, saídas, divergência e resumo por forma de pagamento.</p></div><div class="page-actions"><button class="btn btn-primary" data-cash-action="open">Abrir caixa</button><button class="btn btn-light" data-cash-action="close">Fechar caixa</button></div></section>
<section class="dashboard-grid" id="cashKpis"></section>
<section class="panel"><div class="panel-header"><h3>Movimentações do caixa</h3><span class="badge badge-info" id="cashStatus">Fechado</span></div><div class="action-grid"><button class="btn btn-light" data-cash-action="sangria">Sangria</button><button class="btn btn-light" data-cash-action="suprimento">Suprimento</button><button class="btn btn-light" data-cash-action="entrada">Entrada</button><button class="btn btn-light" data-cash-action="saida">Saída</button><button class="btn btn-warning" data-cash-action="divergencia">Simular divergência</button></div><div class="table-responsive"><table class="table admin-table"><thead><tr><th>Hora</th><th>Tipo</th><th>Valor</th><th>Forma</th></tr></thead><tbody id="cashRows"></tbody></table></div></section>
