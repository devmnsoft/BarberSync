@{ ViewData["Title"] = "Channel Manager"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="page-header"><div><h1 class="page-title">Channel Manager</h1><p class="page-subtitle">Admin controlando PublicWeb, Totem e Mobile com publicação de serviços, campanhas, pagamentos e preview omnichannel.</p></div><div class="page-actions"><button class="btn btn-primary" data-channel-refresh>Atualizar preview</button><a class="btn btn-light" href="/Admin/SaasControlCenter">SaaS Control Center</a></div></section>
<section class="channel-grid" data-channel-manager></section>
<section class="saas-grid"><article class="saas-card wide"><h3>Serviços por canal</h3><div class="saas-list" data-channel-services></div></article><article class="saas-card"><h3>Ações omnichannel</h3><div class="saas-actions"><button class="btn btn-primary" data-channel-action="campaign">Publicar campanha no PublicWeb</button><button class="btn btn-primary" data-channel-action="kiosk">Liberar serviço no Totem</button><button class="btn btn-primary" data-channel-action="mobile">Enviar promoção Mobile</button><button class="btn btn-light" data-channel-action="attendance">Simular atendimento no Totem</button></div></article></section>
