@model BarberSync.AdminWeb.Controllers.AdminController.AdminModuleViewModel
@{ ViewData["Title"] = "Clients"; }
<section class="admin-page-header"><h1>Clients</h1><p>Painel operacional com dados e ações do módulo.</p></section>
<div class="alert alert-warning d-none" id="ClientsFallback">Dados demonstrativos carregados porque a API não respondeu.</div>
<div class="row g-3" id="ClientsCards"></div>
<div class="card mt-3 p-3">
  <div class="d-flex justify-content-between"><h5>Lista de Clients</h5><button class="btn btn-primary">Novo</button></div>
  <div class="table-responsive mt-2"><table class="table table-dark table-striped"><thead><tr><th>Nome</th><th>Status</th><th>Ações</th></tr></thead><tbody id="ClientsRows"></tbody></table></div>
</div>
<script src="~/js/admin-api-client.js"></script>
<script src="~/js/admin-crud.js"></script>
<script>window.renderAdminCrudPage && window.renderAdminCrudPage('Clients')</script>
