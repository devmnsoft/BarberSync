@{
    ViewData["Title"] = "Clients";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="page-header"><div><div class="page-title">Clients</div><div class="page-subtitle">Gestão do módulo com dados demo e ações rápidas.</div></div><div><button class="btn btn-primary">Novo</button></div></div>
<section class="kpi-grid">
  <article class="kpi-card"><div class="kpi-icon">📈</div><div class="kpi-value">128</div><div class="kpi-label">Indicador principal</div></article>
  <article class="kpi-card"><div class="kpi-icon">✅</div><div class="kpi-value">93%</div><div class="kpi-label">Eficiência</div></article>
  <article class="kpi-card"><div class="kpi-icon">⏱️</div><div class="kpi-value">24h</div><div class="kpi-label">SLA médio</div></article>
</section>
<section class="panel" style="margin-top:16px"><div class="panel-header"><h3>Lista operacional</h3><button class="btn btn-secondary">Filtrar</button></div>
<table class="table"><thead><tr><th>Item</th><th>Status</th><th>Ação</th></tr></thead><tbody><tr><td>Registro demo A</td><td><span class="badge badge-success">Ativo</span></td><td><button class="btn btn-secondary">Editar</button></td></tr><tr><td>Registro demo B</td><td><span class="badge badge-warning">Pendente</span></td><td><button class="btn btn-danger">Remover</button></td></tr></tbody></table></section>
<div class="modal" style="display:none">Modal de criação/edição</div>
