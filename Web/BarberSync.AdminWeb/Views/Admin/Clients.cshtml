@{
    ViewData["Title"] = "Clientes";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<section class="page-header">
    <div>
        <h1 class="page-title">Clientes</h1>
        <p class="page-subtitle">Base 360º, histórico e fidelidade. Dados carregados por proxy MVC <strong>/AdminApi/clients</strong> com fallback demo.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-light" data-admin-refresh="Clients">Atualizar</button>
        <button class="btn btn-primary" data-admin-new="Clients">Novo Cliente</button>
    </div>
</section>
<div class="alert alert-warning d-none" id="ClientsFallback">API indisponível: modo demonstração seguro ativo.</div>
<section class="admin-module-grid" id="ClientsCards">
    <article class="kpi-card"><div class="kpi-icon">💈</div><div><p class="kpi-label">Carregando</p><strong class="kpi-value">...</strong><span class="kpi-variation">BarberSync</span></div></article>
</section>
<section class="enterprise-demo-grid"><article class="enterprise-card wide"><h3>Cliente 360</h3><p>Visão unificada com histórico, preferências, cashback, tags e próxima melhor ação.</p><div class="tag-list"><span class="tag">VIP</span><span class="tag">Retorno 21 dias</span><span class="tag">Prefere Rafael</span><span class="tag">Cashback ativo</span></div></article><article class="enterprise-card"><h3>Jornada</h3><div class="timeline-demo"><div>Agendou pelo PublicWeb</div><div>Check-in no Totem</div><div>Comanda paga via PIX</div><div>Avaliação NPS 10</div></div></article><article class="enterprise-card full"><h3>Ações rápidas</h3><div class="quick-actions-grid"><a class="btn btn-light" href="/Admin/Appointments">Agendar</a><a class="btn btn-light" href="/Admin/ServiceOrders">Abrir comanda</a><a class="btn btn-light" href="/Admin/Campaigns">Enviar campanha</a><button class="btn btn-primary" data-demo-action="Histórico 360 aberto">Ver histórico</button></div></article></section>
<section class="panel module-panel">
    <div class="panel-header">
        <div><h3>Registros operacionais</h3><p>CRUD demonstrável com modais, toasts e fallback controlado.</p></div>
        <span class="badge badge-info">/AdminApi/clients</span>
    </div>
    <div class="table-responsive">
        <table class="table admin-table"><thead><tr><th>Nome</th><th>Detalhe</th><th>Status</th><th>Ações</th></tr></thead><tbody id="ClientsRows"><tr><td colspan="4">Carregando...</td></tr></tbody></table>
    </div>
</section>
<div class="admin-modal-backdrop" id="ClientsModal" hidden>
    <form class="admin-modal" data-admin-form="Clients">
        <div class="modal-header"><h3>Novo/editar Cliente</h3><button type="button" class="modal-close" data-admin-close="Clients">×</button></div>
        <label>Nome<input name="name" required placeholder="Nome" /></label>
        <label>Status<select name="status"><option>Ativo</option><option>Em atendimento</option><option>Pendente</option></select></label>
        <label>Observação<input name="notes" placeholder="Observação demo" /></label>
        <div class="modal-actions"><button type="button" class="btn btn-light" data-admin-close="Clients">Cancelar</button><button class="btn btn-primary" type="submit">Salvar</button></div>
    </form>
</div>
@section Scripts {<script>window.renderAdminCrudPage && window.renderAdminCrudPage('Clients')</script>}
