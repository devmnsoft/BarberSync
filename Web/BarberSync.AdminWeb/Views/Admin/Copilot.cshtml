@{ ViewData["Title"] = "Copilot IA"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="page-header"><div><h1 class="page-title">Copilot IA</h1><p class="page-subtitle">Olá, eu sou o Copilot BarberSync. Posso analisar sua operação e sugerir ações.</p></div><div class="page-actions"><a class="btn btn-light" href="/Admin/Campaigns">Criar campanha</a><a class="btn btn-primary" href="/Admin/Appointments">Abrir agenda</a></div></section>
<section class="panel copilot-chat" id="CopilotChat"><div class="copilot-message assistant"><strong>Copilot BarberSync</strong><p>Olá, eu sou o Copilot BarberSync. Posso analisar sua operação e sugerir ações.</p></div><div class="row-actions"><button data-quick-question="Quais clientes devo reativar hoje?">Clientes para reativar</button><button data-quick-question="Qual produto está crítico no estoque?">Estoque crítico</button><button data-quick-question="Que campanha devo criar agora?">Campanha sugerida</button></div><form id="CopilotAsk" class="public-form"><textarea name="question" required placeholder="Faça uma pergunta para o Copilot"></textarea><button class="btn btn-primary" type="submit">Enviar pergunta</button></form><div id="CopilotAnswers" class="module-feature-grid"><article class="feature-card"><span class="priority-high">Alta</span><h4>Repor Pomada Modeladora</h4><p>Estoque abaixo do mínimo e item vendido junto com Corte + Barba.</p><a href="/Admin/Stock">Ver estoque</a></article><article class="feature-card"><span class="priority-medium">Média</span><h4>Criar campanha de retorno</h4><p>18 clientes estão há mais de 45 dias sem atendimento.</p><a href="/Admin/Campaigns">Criar campanha</a></article><article class="feature-card"><span class="priority-low">Baixa</span><h4>Otimizar agenda</h4><p>Antecipe confirmações dos horários de pico.</p><a href="/Admin/Appointments">Abrir agenda</a></article></div></section>
@section Scripts {<script src="~/js/admin-copilot.js" asp-append-version="true"></script>}
