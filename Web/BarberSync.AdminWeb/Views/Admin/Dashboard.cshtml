@{ ViewData["Title"] = "Dashboard"; }
<div class="page-header"><div><h1 class="page-title">Dashboard Executivo</h1><p class="page-subtitle">Visão SaaS completa da operação BarberSync.</p></div><div class="page-actions"><button class="btn btn-light">Exportar</button><button class="btn btn-gold">Copilot</button><button class="btn btn-primary">Novo Agendamento</button></div></div>
<section class="kpi-grid" data-dashboard-kpis>
@for (var i=1;i<=12;i++){<article class="kpi-card"><div class="kpi-icon">📊</div><div><p class="kpi-label">Indicador @i</p><strong class="kpi-value">--</strong><span class="kpi-variation">demo</span></div></article>}
</section>
<div class="dashboard-grid">
<article class="panel span-6"><h3>Receita últimos 7 dias</h3><p>R$ 32.940,00</p></article>
<article class="panel span-6"><h3>Serviços mais vendidos</h3><ul><li>Corte Masculino</li><li>Corte + Barba</li><li>Barba Tradicional</li></ul></article>
<article class="panel span-4"><h3>Próximos agendamentos</h3><p>10:00 Rafael • Corte + Barba</p></article>
<article class="panel span-4"><h3>Estoque crítico</h3><p>8 itens com reposição pendente.</p></article>
<article class="panel span-4"><h3>Copilot</h3><p>Ative campanha de retorno para clientes inativos.</p></article>
</div>
@section Scripts{<script>window.dashboardKpis=window.dashboardKpis||[];</script>}
