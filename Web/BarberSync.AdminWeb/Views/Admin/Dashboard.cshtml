@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="page-header"><div><div class="page-title">Dashboard Executivo</div><div class="page-subtitle">Visão em tempo real da Barbearia Elite Demo.</div></div><div><button class="btn btn-secondary">Atualizar</button> <button class="btn btn-primary">Novo Agendamento</button></div></div>
<section class="kpi-grid">
@foreach (var k in new[] {"Receita hoje|R$ 4.850,00|💵","Receita mês|R$ 92.340,00|📆","Agendamentos hoje|26|📅","Clientes ativos|412|👥","Atendimentos em andamento|4|🪑","Comandas abertas|7|🧾","Ticket médio|R$ 126,00|🎟️","Estoque crítico|8|📦","Avaliação média|4.8|⭐","Totem online|2|🖥️","Campanhas ativas|5|🎯","Profissionais disponíveis|6|💈"}) {
 var p=k.Split('|'); <article class="kpi-card"><div class="kpi-icon">@p[2]</div><div class="kpi-value">@p[1]</div><div class="kpi-label">@p[0]</div></article>
}
</section>
<div style="display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-top:16px"><section class="panel"><h3>Receita últimos 7 dias</h3><div class="loading-skeleton">▁▃▅▆▇▆▅</div></section><section class="panel"><h3>Alertas</h3><ul><li>8 itens em estoque crítico.</li><li>2 avaliações aguardando resposta.</li></ul></section></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px"><section class="panel"><h3>Próximos agendamentos</h3><table class="table"><tr><td>10:00</td><td>Corte + Barba</td><td>Rafael</td></tr><tr><td>10:40</td><td>Barba Tradicional</td><td>Lucas</td></tr></table></section><section class="panel"><h3>Sugestões do Copilot</h3><ul><li>Ativar campanha de retorno para clientes inativos há 30 dias.</li><li>Criar combo Corte + Hidratação com desconto progressivo.</li></ul></section></div>
