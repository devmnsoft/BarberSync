@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<header class="page-header">
    <div>
        <h1 class="page-title">Dashboard Executivo</h1>
        <p class="page-subtitle">Visão em tempo real da Barbearia Elite Demo.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-secondary">Atualizar</button>
        <button class="btn btn-primary">Novo Agendamento</button>
    </div>
</header>

<section class="kpi-grid" data-dashboard-kpis></section>

<section class="dashboard-panels dashboard-panels-lg">
    <article class="panel">
        <h3>Receita últimos 7 dias</h3>
        <div class="chart-placeholder">▁▃▅▆▇▆▅</div>
    </article>
    <article class="panel">
        <h3>Alertas</h3>
        <ul class="list-clean">
            <li>8 itens em estoque crítico.</li>
            <li>2 avaliações aguardando resposta.</li>
        </ul>
    </article>
</section>

<section class="dashboard-panels">
    <article class="panel">
        <h3>Próximos agendamentos</h3>
        <table class="table">
            <tr><td>10:00</td><td>Corte + Barba</td><td>Rafael</td></tr>
            <tr><td>10:40</td><td>Barba Tradicional</td><td>Lucas</td></tr>
        </table>
    </article>
    <article class="panel">
        <h3>Sugestões do Copilot</h3>
        <ul class="list-clean">
            <li>Ativar campanha de retorno para clientes inativos há 30 dias.</li>
            <li>Criar combo Corte + Hidratação com desconto progressivo.</li>
        </ul>
    </article>
</section>

@section Scripts {
<script>
    window.dashboardKpis = [
        { label: "Receita hoje", value: "R$ 4.850,00", icon: "💰", variation: "+12%" },
        { label: "Receita mês", value: "R$ 92.340,00", icon: "📈", variation: "+18%" },
        { label: "Agendamentos hoje", value: "26", icon: "📅", variation: "+7%" },
        { label: "Clientes ativos", value: "412", icon: "👥", variation: "+22" },
        { label: "Atendimentos em andamento", value: "4", icon: "✂️", variation: "Agora" },
        { label: "Comandas abertas", value: "7", icon: "🧾", variation: "Agora" },
        { label: "Ticket médio", value: "R$ 126,00", icon: "🎯", variation: "+9%" },
        { label: "Estoque crítico", value: "8", icon: "📦", variation: "Atenção" },
        { label: "Avaliação média", value: "4.8", icon: "⭐", variation: "Excelente" },
        { label: "Totem online", value: "2", icon: "🖥️", variation: "Online" },
        { label: "Campanhas ativas", value: "5", icon: "🎯", variation: "Ativas" },
        { label: "Profissionais disponíveis", value: "6", icon: "💈", variation: "Hoje" }
    ];
</script>
}
