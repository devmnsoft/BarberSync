@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Dashboard Executivo</div>
        <div class="page-subtitle">Visão em tempo real da Barbearia Elite Demo.</div>
    </div>
    <div>
        <button class="btn btn-secondary">Atualizar</button>
        <button class="btn btn-primary">Novo Agendamento</button>
    </div>
</div>

<section class="kpi-grid" data-dashboard-kpis></section>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-top:16px">
    <section class="panel"><h3>Receita últimos 7 dias</h3><div class="loading-skeleton">▁▃▅▆▇▆▅</div></section>
    <section class="panel"><h3>Alertas</h3><ul><li>8 itens em estoque crítico.</li><li>2 avaliações aguardando resposta.</li></ul></section>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px">
    <section class="panel"><h3>Próximos agendamentos</h3><table class="table"><tr><td>10:00</td><td>Corte + Barba</td><td>Rafael</td></tr><tr><td>10:40</td><td>Barba Tradicional</td><td>Lucas</td></tr></table></section>
    <section class="panel"><h3>Sugestões do Copilot</h3><ul><li>Ativar campanha de retorno para clientes inativos há 30 dias.</li><li>Criar combo Corte + Hidratação com desconto progressivo.</li></ul></section>
</div>

@section Scripts {
<script>
    window.dashboardKpis = [
        { label: "Receita hoje", value: "R$ 4.850,00", icon: "💰", variation: "+12%" },
        { label: "Receita mês", value: "R$ 92.340,00", icon: "📈", variation: "+18%" },
        { label: "Agendamentos hoje", value: "26", icon: "📅", variation: "+7%" },
        { label: "Clientes ativos", value: "412", icon: "👥", variation: "+22" },
        { label: "Atendimentos em andamento", value: "4", icon: "✂️", variation: "Agora" },
        { label: "Comandas abertas", value: "7", icon: "🧾", variation: "Agora" },
        { label: "Ticket médio", value: "R$ 126,00", icon: "🎯", variation: "+9%" },
        { label: "Estoque crítico", value: "8", icon: "📦", variation: "Atenção" },
        { label: "Avaliação média", value: "4.8", icon: "⭐", variation: "Excelente" },
        { label: "Totem online", value: "2", icon: "🖥️", variation: "Online" },
        { label: "Campanhas ativas", value: "5", icon: "🎯", variation: "Ativas" },
        { label: "Profissionais disponíveis", value: "6", icon: "💈", variation: "Hoje" }
    ];
</script>
}
