@{ ViewData["Title"] = "Central da Demo"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="page-header">
  <div><h1 class="page-title">Central da Demo BarberSync 4.0</h1><p class="page-subtitle">Controle cenários, integrações PublicWeb/Totem, eventos, estado local persistente e roteiro comercial integrado.</p></div>
  <div class="page-actions"><a class="btn btn-light" href="/Admin/Help">Abrir roteiro</a><a class="btn btn-light" href="/Admin/PublicSite" target="_blank" rel="noopener">Abrir PublicWeb</a><a class="btn btn-light" href="/Admin/Kiosk" target="_blank" rel="noopener">Abrir Totem</a><a class="btn btn-primary" href="/AdminApi/swagger.json" target="_blank" rel="noopener">Abrir Swagger</a></div>
</section>
<section class="enterprise-demo-grid">
  <article class="enterprise-card wide"><h3>Status do modo demo</h3><div class="tag-list" data-demo-status></div><div class="quick-actions-grid"><button class="btn btn-light" data-demo-scenario="busyDay">Dia movimentado</button><button class="btn btn-light" data-demo-scenario="criticalStock">Estoque crítico</button><button class="btn btn-light" data-demo-scenario="highRevenue">Alto faturamento</button><button class="btn btn-light" data-demo-scenario="campaignMode">Campanhas ativas</button><button class="btn btn-light" data-demo-scenario="kioskDemo">Totem em uso</button><button class="btn btn-primary" data-demo-reset>Resetar dados demo</button></div></article>
  <article class="enterprise-card"><h3>Importações demo</h3><p>Como localStorage é isolado por porta, a importação simula dados equivalentes no Admin.</p><div class="quick-actions-grid"><button class="btn btn-primary" data-demo-import-public>Importar leads públicos demo</button><button class="btn btn-secondary" data-demo-import-kiosk>Importar atendimentos do Totem demo</button></div></article>
  <article class="enterprise-card"><h3>Exportar/importar JSON</h3><textarea data-demo-json rows="7" placeholder="Cole ou gere o estado JSON"></textarea><div class="quick-actions-grid"><button class="btn btn-light" data-demo-export>Exportar estado</button><button class="btn btn-light" data-demo-import>Importar estado</button></div></article>
</section>
<section class="panel module-panel"><div class="panel-header"><div><h3>Últimos eventos</h3><p>Eventos emitidos pelo EventBus e persistidos no DemoStore.</p></div><span class="badge badge-success">barbersync.demo.state.v4</span></div><ul class="metric-list" data-demo-events></ul></section>
@section Scripts {<script src="~/js/admin-demo-center.js" asp-append-version="true"></script>}
