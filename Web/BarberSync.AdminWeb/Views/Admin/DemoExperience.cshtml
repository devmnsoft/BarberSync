@{ ViewData["Title"] = "Demo Experience"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="page-header"><div><h1 class="page-title">BarberSync Demo Experience 5.0</h1><p class="page-subtitle">Console comercial para conduzir captação, agenda, atendimento, comanda, pagamento, estoque, cashback, avaliação, campanha, Copilot, PublicWeb, Totem e Mobile.</p></div><div class="page-actions"><button class="btn btn-primary" data-demo5-start>Iniciar demonstração guiada</button><button class="btn btn-light" data-demo5-scenario="dia-movimentado">Carregar cenário completo</button><button class="btn btn-light" data-demo5-reset>Resetar dados demo</button></div></section>
<section class="demo5-hero"><article class="demo5-card"><span class="badge badge-success">SaaS enterprise integrado</span><h2>Uma narrativa única, do lead ao dashboard executivo.</h2><p>Use os botões abaixo para abrir canais e executar um roteiro sem telas vazias ou estados quebrados.</p><div class="demo5-actions"><a class="btn btn-light" href="/Admin/PublicSite" target="_blank" rel="noopener">Abrir PublicWeb</a><a class="btn btn-light" href="/Admin/Kiosk" target="_blank" rel="noopener">Abrir Totem</a><a class="btn btn-light" href="/Admin/Dashboard">Abrir Dashboard</a><button class="btn btn-primary" data-demo5-flow>Executar fluxo cliente → pagamento</button></div></article><article class="demo5-card light"><h3>Status dos módulos</h3><div class="demo5-status" data-demo5-status></div></article></section>
<section class="demo5-grid"><article class="demo5-card light"><h3>Cenários disponíveis</h3><div class="demo5-actions" data-demo5-scenarios></div></article><article class="demo5-card light"><h3>Checklist visual</h3><div class="demo5-checklist" data-demo5-checklist></div></article></section>
<section class="demo5-grid"><article class="demo5-card light"><h3>Linha do tempo da demo</h3><div class="demo5-timeline" data-demo5-timeline></div></article><article class="demo5-card light"><h3>Eventos recentes</h3><div class="demo5-events" data-demo5-events></div></article></section>
