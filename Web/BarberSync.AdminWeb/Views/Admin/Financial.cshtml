@{ ViewData["Title"] = "Central Financeira Executiva"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="page-header"><div><h1 class="page-title">Central Financeira Executiva</h1><p class="page-subtitle">Receita diária e mensal, canais, meios de pagamento, comissões, cashback, descontos, ticket médio, fluxo de caixa e DRE simplificada demo.</p></div><div class="page-actions"><button class="btn btn-light" data-financial-action="dre">Gerar DRE</button><button class="btn btn-primary" data-financial-action="forecast">Projetar mês</button></div></section>
<section id="financialKpis" class="dashboard-grid"></section>
<section class="saas-hero-grid"><article class="panel"><div class="panel-header"><h3>Receita por canal</h3><span class="badge badge-info">Omnichannel</span></div><div id="financialChannels" class="usage-grid"></div></article><article class="panel"><div class="panel-header"><h3>Pagamentos por forma</h3><span class="badge badge-success">Conciliado mock</span></div><div id="financialPayments" class="usage-grid"></div></article></section>
<section class="panel"><div class="panel-header"><h3>Fluxo de caixa e DRE simplificada</h3><span class="badge badge-info">DemoStore</span></div><div class="table-responsive"><table class="table admin-table"><thead><tr><th>Indicador</th><th>Valor</th><th>Leitura executiva</th></tr></thead><tbody id="financialDre"></tbody></table></div><pre id="financialLog" class="demo-console">Pronto para simular relatórios financeiros.</pre></section>
