@{ ViewData["Title"] = "Roteiro de demonstração"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="page-header"><div><h1 class="page-title">BarberSync Demo Experience 1.0</h1><p class="page-subtitle">Manual rápido para apresentar o SaaS para salões, barbearias, estética e franquias.</p></div><div class="page-actions"><button class="btn btn-light" data-demo-action="Checklist Docs/CHECKLIST_DEMO.md validado">Checklist</button><button class="btn btn-primary" data-command-open>Ctrl + K</button></div></section>
<section class="enterprise-demo-grid">
  <article class="enterprise-card"><h3>1. PublicWeb</h3><p>Mostre CTA, serviços, profissionais, planos e solicitação de demonstração.</p><a class="btn btn-light" href="/Admin/PublicSite" target="_blank" rel="noopener">Abrir PublicWeb</a></article>
  <article class="enterprise-card"><h3>2. Admin</h3><p>Use command palette, onboarding, ajuda contextual e dashboard executivo.</p><a class="btn btn-light" href="/Admin/Dashboard">Abrir dashboard</a></article>
  <article class="enterprise-card"><h3>3. Operação</h3><p>Crie cliente, avance agenda, abra comanda, simule pagamento e imprima recibo.</p><a class="btn btn-light" href="/Admin/Clients">Começar Cliente 360</a></article>
  <article class="enterprise-card"><h3>4. Gestão</h3><p>Mostre estoque crítico, campanha, cupom, fidelidade, avaliações e NPS.</p><a class="btn btn-light" href="/Admin/Stock">Abrir estoque</a></article>
  <article class="enterprise-card"><h3>5. Copilot</h3><p>Pergunte sobre clientes inativos e converta resposta em campanha ou reposição.</p><a class="btn btn-light" href="/Admin/Copilot">Abrir Copilot</a></article>
  <article class="enterprise-card"><h3>6. Totem</h3><p>Conclua autoatendimento com resumo lateral, pagamento mock, sucesso e avaliação.</p><a class="btn btn-light" href="/Admin/Kiosk" target="_blank" rel="noopener">Abrir Totem</a></article>
</section>
<section class="panel"><h3>Checklist de aceite</h3><ul class="metric-list"><li>Command palette existe e abre com Ctrl + K.</li><li>Demo store persiste CRUDs em localStorage.</li><li>Browser não chama a URL interna da API diretamente.</li><li>Totem conclui fluxo e reseta em 10 segundos.</li><li>Documentação inclui Docs/CHECKLIST_DEMO.md.</li></ul></section>
