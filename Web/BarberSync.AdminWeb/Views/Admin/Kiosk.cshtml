@{ ViewData["Title"] = "Gestão do Totem"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="saas7-hero" data-kiosk-settings-page><div><span class="badge">Canais > Totem</span><h1>Gestão do Totem</h1><p>Configuração visual de dispositivos, serviços, pagamentos, acessibilidade, experiência e logs do autoatendimento.</p></div><div class="saas7-actions"><button class="btn btn-gold" form="KioskSettingsForm">Salvar Totem</button><button class="btn btn-light" type="button" data-open-kiosk>Abrir Totem</button><button class="btn btn-light" type="button" data-simulate-kiosk>Simular atendimento</button></div></section>
<section class="saas7-grid">
  <article class="saas7-card wide"><h2>Dispositivos</h2><table class="saas7-table"><thead><tr><th>DeviceCode</th><th>Nome</th><th>Unidade</th><th>Status</th><th>Última comunicação</th><th>Versão</th></tr></thead><tbody data-kiosk-devices></tbody></table></article>
  <article class="saas7-card"><h2>Preview do Totem</h2><div data-saas7-kiosk-preview></div></article>
  <article class="saas7-card"><h2>Serviços liberados</h2><div class="saas7-list" data-kiosk-services></div></article>
  <article class="saas7-card wide"><h2>Pagamentos e experiência</h2><form id="KioskSettingsForm" class="saas7-form" data-kiosk-form><label class="full">Mensagem inicial<textarea name="message"></textarea></label><label>Timeout (segundos)<input name="timeout" type="number"></label><label class="saas7-switch"><input name="highContrast" type="checkbox"> Alto contraste</label><label class="saas7-switch"><input name="largeFont" type="checkbox"> Fonte grande</label><label class="saas7-switch"><input name="attendant" type="checkbox"> Chamar atendente</label><label class="saas7-switch"><input name="autoReset" type="checkbox"> Reset automático</label><label class="saas7-switch"><input name="pix" type="checkbox"> PIX</label><label class="saas7-switch"><input name="card" type="checkbox"> Cartão</label><label class="saas7-switch"><input name="cash" type="checkbox"> Dinheiro</label><label class="saas7-switch"><input name="reception" type="checkbox"> Pagamento na recepção</label><label class="saas7-switch"><input name="mock" type="checkbox"> Mock habilitado</label></form></article>
  <article class="saas7-card full"><h2>Logs do Totem</h2><div data-kiosk-logs></div></article>
</section>
