@{ ViewData["Title"] = "Lead to Cash"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="page-header"><div><h1 class="page-title">Lead to Cash</h1><p class="page-subtitle">Lead → Cliente → Agendamento → Atendimento → Comanda → Pagamento → Fidelidade → Avaliação, com ações que atualizam DemoStore, EventBus e Dashboard.</p></div><div class="page-actions"><button class="btn btn-gold" data-ltc-run>Executar fluxo completo</button><a class="btn btn-light" href="/Admin/Dashboard">Ver Dashboard</a></div></section>
<section class="lead-stepper" data-ltc-stepper></section>
<section class="saas-grid"><article class="saas-card wide"><h3>Ações por etapa</h3><div class="saas-actions"><button class="btn btn-primary" data-ltc-action="lead">Criar lead demo</button><button class="btn btn-primary" data-ltc-action="client">Converter lead em cliente</button><button class="btn btn-primary" data-ltc-action="appointment">Criar agendamento</button><button class="btn btn-primary" data-ltc-action="checkin">Fazer check-in</button><button class="btn btn-primary" data-ltc-action="start">Iniciar atendimento</button><button class="btn btn-primary" data-ltc-action="order">Abrir comanda</button><button class="btn btn-primary" data-ltc-action="pay">Pagar comanda</button><button class="btn btn-primary" data-ltc-action="review">Gerar avaliação</button><button class="btn btn-gold" data-ltc-action="campaign">Gerar campanha de retorno</button></div></article><article class="saas-card"><h3>Métricas do funil</h3><div class="saas-list" data-ltc-metrics></div></article><article class="saas-card full"><h3>Timeline integrada</h3><ul class="timeline-list" data-ltc-events></ul></article></section>
