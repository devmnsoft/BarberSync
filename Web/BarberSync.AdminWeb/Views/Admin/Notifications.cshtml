@{ ViewData["Title"] = "Notificações"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="saas7-hero" data-notifications-page><div><span class="badge">Topbar > Notificações</span><h1>Notificações internas</h1><p>Alertas operacionais gerados pela experiência demo/EventBus: agenda, chegada do cliente, estoque crítico, comanda, pagamento, avaliação, campanha, Totem e Copilot.</p></div><div class="saas7-actions"><span class="badge"><strong data-notification-count>0</strong> não lidas</span><button class="btn btn-gold" data-read-all>Marcar todas como lidas</button></div></section>
<section class="saas7-grid"><article class="saas7-card wide"><h2>Lista de notificações</h2><div class="saas7-list" data-notifications-list></div></article><article class="saas7-card"><h2>Preferências demo</h2><div class="saas7-list"><label class="saas7-switch"><input type="checkbox" checked> Agenda e clientes</label><label class="saas7-switch"><input type="checkbox" checked> Estoque e compras</label><label class="saas7-switch"><input type="checkbox" checked> Totem e canais</label><label class="saas7-switch"><input type="checkbox" checked> Copilot recomenda ação</label></div></article></section>
