@{ ViewData["Title"] = "Configurações da Plataforma"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="saas7-hero"><div><span class="badge">BarberSync Stable Demo Release 13.0</span><h1>Configurações da Plataforma</h1><p>Central visual para identidade, dados da empresa, horários, regras financeiras, agendamento e canais. Tudo salva no DemoStore/localStorage e atualiza os previews de Admin, PublicWeb e Totem.</p></div><div class="saas7-actions"><button class="btn btn-gold" form="PlatformSettingsForm">Salvar configurações</button><button class="btn btn-light" type="button" onclick="window.BarberSyncSaas7?.save(); window.AdminToast?.showInfo('Configuração demo sincronizada.');">Aplicar branding</button><button class="btn btn-light" type="button" data-platform-reset>Restaurar padrão</button><a class="btn btn-light" href="/Admin/PublicSite" target="_blank" rel="noopener">Ver PublicWeb</a><a class="btn btn-light" href="/Admin/Kiosk" target="_blank" rel="noopener">Ver Totem</a></div></section>
<form id="PlatformSettingsForm" class="saas7-grid" data-platform-form>
  <article class="saas7-card"><h2>Dados da empresa</h2><div class="saas7-form"><label>Nome fantasia<input name="tradeName"></label><label>Razão social demo<input name="legalName"></label><label>CNPJ demo<input name="cnpj"></label><label>Telefone<input name="phone"></label><label>WhatsApp<input name="whatsapp"></label><label>E-mail<input name="email" type="email"></label><label class="full">Endereço<input name="address"></label><label>Cidade<input name="city"></label><label>Estado<input name="state"></label><label>Cidade/UF<input name="cityUf"></label></div></article>
  <article class="saas7-card"><h2>Identidade visual</h2><div class="saas7-form"><label>Logo<input name="logo"></label><label>Cor primária<input name="primary" type="color"></label><label>Cor secundária<input name="secondary" type="color"></label><label>Tema<select name="theme"><option>Claro</option><option>Escuro</option></select></label><label>Nome no PublicWeb<input name="publicName"></label><label>Nome no Totem<input name="kioskName"></label><label class="full">Slogan<textarea name="slogan"></textarea></label></div></article>
  <article class="saas7-card"><h2>Horário de funcionamento</h2><div class="saas7-form"><label class="full">Segunda a domingo, início/fim e intervalos<textarea name="hours"></textarea></label><label class="full">Feriados demo<textarea name="holidays"></textarea></label></div></article>
  <article class="saas7-card"><h2>Regras de agendamento</h2><div class="saas7-form"><label>Antecedência mínima<input name="minAdvance"></label><label>Intervalo entre serviços<input name="serviceInterval"></label><label>Tolerância de atraso<input name="delayTolerance"></label><label class="full">Política de cancelamento<textarea name="cancelPolicy"></textarea></label><label class="saas7-switch full"><input name="autoConfirm" type="checkbox"> Confirmação automática demo</label></div></article>
  <article class="saas7-card"><h2>Regras financeiras</h2><div class="saas7-form"><label>Comissão padrão %<input name="commission" type="number"></label><label>Cashback padrão %<input name="cashback" type="number"></label><label>Desconto máximo demo %<input name="maxDiscount" type="number"></label><label class="full">Formas habilitadas<input value="PIX, Cartão, Dinheiro, Pagamento na recepção" readonly></label></div></article>
  <article class="saas7-card"><h2>Canais</h2><div class="saas7-list"><label class="saas7-switch"><input name="publicWeb" type="checkbox"> PublicWeb ativo</label><label class="saas7-switch"><input name="kiosk" type="checkbox"> Totem ativo</label><label class="saas7-switch"><input name="mobile" type="checkbox"> Mobile ativo</label><label class="saas7-switch"><input name="copilot" type="checkbox"> Copilot ativo</label></div></article>
  <article class="saas7-card wide"><h2>Preview PublicWeb</h2><div data-saas7-public-preview></div></article><article class="saas7-card"><h2>Preview Totem</h2><div data-saas7-kiosk-preview></div></article>
</form>
