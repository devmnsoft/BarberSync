@{
    ViewData["Title"] = "Profissionais";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<section class="page-header">
    <div>
        <h1 class="page-title">Profissionais</h1>
        <p class="page-subtitle">Escala, performance e disponibilidade. Dados carregados por proxy MVC <strong>/AdminApi/professionals</strong> com fallback demo.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-light" data-admin-refresh="Professionals">Atualizar</button>
        <button class="btn btn-primary" data-admin-new="Professionals">Novo Profissional</button>
    </div>
</section>
<div class="alert alert-warning d-none" id="ProfessionalsFallback">API indisponível: modo demonstração seguro ativo.</div>
<section class="admin-module-grid" id="ProfessionalsCards">
    <article class="kpi-card"><div class="kpi-icon">💈</div><div><p class="kpi-label">Carregando</p><strong class="kpi-value">...</strong><span class="kpi-variation">BarberSync</span></div></article>
</section>
<section class="enterprise-demo-grid"><article class="enterprise-card"><h3>Performance</h3><p>R$ 18.450 no mês • ⭐ 4,9 • 92% ocupação.</p><div class="progress-demo"><span style="width:84%"></span></div></article><article class="enterprise-card"><h3>Comissão estimada</h3><strong>R$ 7.380</strong><p>Baseada nas comandas concluídas.</p></article><article class="enterprise-card"><h3>Agenda de hoje</h3><div class="timeline-demo"><div>10:30 Lucas</div><div>14:00 Marina</div><div>18:30 André</div></div></article><article class="enterprise-card full"><h3>Serviços vinculados e ranking</h3><div class="tag-list"><span class="tag">Corte + Barba</span><span class="tag">Fade</span><span class="tag">Barba quente</span><span class="tag">#1 faturamento</span></div><div class="quick-actions-grid"><button class="btn btn-light" data-demo-action="Agenda do profissional aberta">Ver agenda</button><button class="btn btn-light" data-demo-action="Comissão calculada">Ver comissão</button><button class="btn btn-light" data-demo-action="Serviço vinculado">Vincular serviço</button><button class="btn btn-light" data-demo-action="Profissional inativado">Inativar</button></div></article></section>
<section class="panel module-panel">
    <div class="panel-header">
        <div><h3>Registros operacionais</h3><p>CRUD demonstrável com modais, toasts e fallback controlado.</p></div>
        <span class="badge badge-info">/AdminApi/professionals</span>
    </div>
    <div class="table-responsive">
        <table class="table admin-table"><thead><tr><th>Nome</th><th>Detalhe</th><th>Status</th><th>Ações</th></tr></thead><tbody id="ProfessionalsRows"><tr><td colspan="4">Carregando...</td></tr></tbody></table>
    </div>
</section>
<div class="admin-modal-backdrop" id="ProfessionalsModal" hidden>
    <form class="admin-modal" data-admin-form="Professionals">
        <div class="modal-header"><h3>Novo/editar Profissional</h3><button type="button" class="modal-close" data-admin-close="Professionals">×</button></div>
        <label>Nome<input name="name" required placeholder="Nome" /></label>
        <label>Status<select name="status"><option>Ativo</option><option>Em atendimento</option><option>Pendente</option></select></label>
        <label>Observação<input name="notes" placeholder="Observação demo" /></label>
        <div class="modal-actions"><button type="button" class="btn btn-light" data-admin-close="Professionals">Cancelar</button><button class="btn btn-primary" type="submit">Salvar</button></div>
    </form>
</div>
@section Scripts {<script>window.renderAdminCrudPage && window.renderAdminCrudPage('Professionals')</script>}
