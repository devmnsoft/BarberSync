@{
    ViewData["Title"] = "AvaliaГ§Гөes";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<section class="page-header">
    <div>
        <h1 class="page-title">AvaliaГ§Гөes</h1>
        <p class="page-subtitle">ReputaГ§ГЈo, notas e comentГЎrios. Dados carregados por proxy MVC <strong>/AdminApi/reviews</strong> com fallback demo.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-light" data-admin-refresh="Reviews">Atualizar</button>
        <button class="btn btn-primary" data-admin-new="Reviews">Novo AvaliaГ§ГЈo</button>
    </div>
</section>
<div class="alert alert-warning d-none" id="ReviewsFallback">API indisponГӯvel: modo demonstraГ§ГЈo seguro ativo.</div>
<section class="admin-module-grid" id="ReviewsCards">
    <article class="kpi-card"><div class="kpi-icon">рҹ’Ҳ</div><div><p class="kpi-label">Carregando</p><strong class="kpi-value">...</strong><span class="kpi-variation">BarberSync</span></div></article>
</section>
<section class="enterprise-demo-grid"><article class="enterprise-card"><h3>NPS</h3><strong>72</strong><p>Promotores em alta.</p></article><article class="enterprise-card"><h3>Estrelas</h3><p>5вӯҗ 78% вҖў 4вӯҗ 14% вҖў 3вӯҗ 8%</p></article><article class="enterprise-card wide"><h3>RecuperaГ§ГЈo</h3><p>Detratores recebem aГ§ГЈo de contato e cupom de reconquista.</p><button class="btn btn-primary" data-demo-action="Plano de recuperaГ§ГЈo criado">Criar recuperaГ§ГЈo</button></article></section>
<section class="panel module-panel">
    <div class="panel-header">
        <div><h3>Registros operacionais</h3><p>CRUD demonstrГЎvel com modais, toasts e fallback controlado.</p></div>
        <span class="badge badge-info">/AdminApi/reviews</span>
    </div>
    <div class="table-responsive">
        <table class="table admin-table"><thead><tr><th>Nome</th><th>Detalhe</th><th>Status</th><th>AГ§Гөes</th></tr></thead><tbody id="ReviewsRows"><tr><td colspan="4">Carregando...</td></tr></tbody></table>
    </div>
</section>
<div class="admin-modal-backdrop" id="ReviewsModal" hidden>
    <form class="admin-modal" data-admin-form="Reviews">
        <div class="modal-header"><h3>Novo/editar AvaliaГ§ГЈo</h3><button type="button" class="modal-close" data-admin-close="Reviews">Г—</button></div>
        <label>Nome<input name="name" required placeholder="Nome" /></label>
        <label>Status<select name="status"><option>Ativo</option><option>Em atendimento</option><option>Pendente</option></select></label>
        <label>ObservaГ§ГЈo<input name="notes" placeholder="ObservaГ§ГЈo demo" /></label>
        <div class="modal-actions"><button type="button" class="btn btn-light" data-admin-close="Reviews">Cancelar</button><button class="btn btn-primary" type="submit">Salvar</button></div>
    </form>
</div>
@section Scripts {<script>window.renderAdminCrudPage && window.renderAdminCrudPage('Reviews')</script>}
