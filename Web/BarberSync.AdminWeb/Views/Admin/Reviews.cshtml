@{ ViewData["Title"] = "Qualidade e Satisfação"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section id="quality" class="page-header"><div><h1 class="page-title">Painel de Qualidade e Satisfação</h1><p class="page-subtitle">NPS, nota média, distribuição por estrelas, rankings, detratores, promotores e plano de recuperação.</p></div><div class="page-actions"><button class="btn btn-light" data-quality-action="training">Criar treinamento</button><button class="btn btn-primary" data-quality-action="coupon">Criar cupom de recuperação</button></div></section>
<section id="qualityKpis" class="dashboard-grid"></section>
<section class="saas-hero-grid"><article class="panel"><h3>Distribuição por estrelas</h3><div id="starDistribution" class="usage-grid"></div></article><article class="panel"><h3>Plano de recuperação</h3><div id="recoveryPlan" class="automation-list"></div></article></section>
<section class="panel"><div class="panel-header"><h3>Comentários e ações</h3><span class="badge badge-info">Promotores e detratores</span></div><div class="table-responsive"><table class="table admin-table"><thead><tr><th>Cliente</th><th>Nota</th><th>NPS</th><th>Comentário</th><th>Ações</th></tr></thead><tbody id="qualityRows"></tbody></table></div></section>
