@{
    ViewData["Title"] = "Comandas";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<section class="page-header">
    <div>
        <h1 class="page-title">Comandas</h1>
        <p class="page-subtitle">Kanban de atendimento e pagamentos mock. Dados carregados por proxy MVC <strong>/AdminApi/service-orders</strong> com fallback demo.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-light" data-admin-refresh="ServiceOrders">Atualizar</button>
        <button class="btn btn-primary" data-admin-new="ServiceOrders">Novo Comanda</button>
    </div>
</section>
<div class="alert alert-warning d-none" id="ServiceOrdersFallback">API indisponível: modo demonstração seguro ativo.</div>
<section class="admin-module-grid" id="ServiceOrdersCards">
    <article class="kpi-card"><div class="kpi-icon">💈</div><div><p class="kpi-label">Carregando</p><strong class="kpi-value">...</strong><span class="kpi-variation">BarberSync</span></div></article>
</section>
<section class="enterprise-demo-grid"><article class="enterprise-card wide"><h3>Kanban de comandas</h3><div class="kanban-demo"><div class="kanban-col"><strong>Abertas</strong><div class="kanban-card">#1001 Lucas • R$ 115</div></div><div class="kanban-col"><strong>Em pagamento</strong><div class="kanban-card">#1002 Marina • R$ 55</div></div><div class="kanban-col"><strong>Fechadas</strong><div class="kanban-card">#0999 André • R$ 95</div></div></div></article><article class="enterprise-card"><h3>Recibo visual</h3><div class="receipt-demo"><strong>BarberSync</strong><p>Corte + Barba R$ 95<br/>Pomada R$ 35<br/>Desconto R$ 10</p><strong>Total R$ 120</strong></div><button class="btn btn-primary" onclick="window.print()">Imprimir recibo</button></article><article class="enterprise-card full"><h3>Pagamento mock</h3><div class="quick-actions-grid"><button class="btn btn-light" data-demo-action="PIX aprovado">PIX</button><button class="btn btn-light" data-demo-action="Cartão aprovado">Cartão</button><button class="btn btn-light" data-demo-action="Dinheiro registrado">Dinheiro</button></div></article></section>
<!-- Demo Experience 3.0 injected -->
<section class="enterprise-demo-grid">
  <article class="enterprise-card wide"><h3>PDV 3.0 visual</h3><p>Busca cliente, adiciona serviço/produto, aplica desconto/cupom/cashback e fecha com PIX, cartão, dinheiro ou misto.</p><div class="quick-actions-grid"><button class="btn btn-primary" onclick="const s=window.BarberSyncDemoStore; const o=s?.get('serviceOrders')?.find(x=>x.status!=='Paga'); if(o){s.addProductToOrder(o.id,'prd-001',1); s.payServiceOrder(o.id,{method:'PIX'}); window.AdminToast?.show('Produto adicionado, PIX aprovado, estoque baixado e cashback gerado.','success'); window.refreshModule?.('ServiceOrders');}">Pagar primeira comanda PIX</button><button class="btn btn-light" onclick="window.print()">Imprimir recibo</button><button class="btn btn-light" data-demo-action="Compartilhamento mock enviado pelo WhatsApp">Compartilhar mock</button></div></article>
  <article class="enterprise-card demo-receipt"><h3>BarberSync</h3><p>Recibo premium demo</p><div class="receipt-total">PIX aprovado</div><small>Cashback e avaliação pendente gerados automaticamente.</small></article>
</section>
<section class="panel module-panel">
    <div class="panel-header">
        <div><h3>Registros operacionais</h3><p>CRUD demonstrável com modais, toasts e fallback controlado.</p></div>
        <span class="badge badge-info">/AdminApi/service-orders</span>
    </div>
    <div class="table-responsive">
        <table class="table admin-table"><thead><tr><th>Nome</th><th>Detalhe</th><th>Status</th><th>Ações</th></tr></thead><tbody id="ServiceOrdersRows"><tr><td colspan="4">Carregando...</td></tr></tbody></table>
    </div>
</section>
<div class="admin-modal-backdrop" id="ServiceOrdersModal" hidden>
    <form class="admin-modal" data-admin-form="ServiceOrders">
        <div class="modal-header"><h3>Novo/editar Comanda</h3><button type="button" class="modal-close" data-admin-close="ServiceOrders">×</button></div>
        <label>Nome<input name="name" required placeholder="Nome" /></label>
        <label>Status<select name="status"><option>Ativo</option><option>Em atendimento</option><option>Pendente</option></select></label>
        <label>Observação<input name="notes" placeholder="Observação demo" /></label>
        <div class="modal-actions"><button type="button" class="btn btn-light" data-admin-close="ServiceOrders">Cancelar</button><button class="btn btn-primary" type="submit">Salvar</button></div>
    </form>
</div>
@section Scripts {<script>window.renderAdminCrudPage && window.renderAdminCrudPage('ServiceOrders')</script>}

<section class="panel"><div class="panel-header"><div><h3>Comanda/PDV integrado</h3><p>Abra comanda, adicione serviços/produtos, pague, gere recibo, baixe estoque e gere cashback.</p></div></div><div class="module-feature-grid" data-service-orders-demo></div></section>

<section class="panel"><div class="panel-header"><div><h3>ServiceOrders 2.0 integrado</h3><p>Ações conectadas ao DemoStore, EventBus, Dashboard, Operação e Cliente 360.</p></div></div><div data-service-orders-v2></div></section>
<section class="saas-grid" data-pdv-30><article class="saas-card wide"><h3>PDV 3.0 • Carrinho integrado</h3><div class="saas-actions"><button class="btn btn-primary" data-pdv-demo>Abrir comanda demo</button><button class="btn btn-light" data-pdv-product>Adicionar produto</button><button class="btn btn-light" data-pdv-coupon>Aplicar cupom</button><button class="btn btn-gold" data-pdv-pay>Pagar, recibo e cashback</button></div><div class="saas-list" data-pdv-cart></div></article><article class="saas-card"><h3>Recibo</h3><div data-pdv-receipt>Recibo será gerado após pagamento.</div></article></section>

<section class="panel"><div class="panel-header"><div><h3>Comanda do Atendimento Completo 14.0</h3><p>Status Open/Paid/Closed, itens, pagamento e recibo acessível.</p></div><a class="btn btn-light" href="/Admin/FullServiceFlow">Abrir fluxo</a></div><div data-flow-service-order></div></section>

<section class="panel"><div class="panel-header"><div><h3>Comanda do Fluxo Comercial 15.0</h3><p>Kanban, lista de itens, recibo e pagamentos gerados no fluxo central.</p></div></div><div data-commercial-flow-order></div></section>
