@{ ViewData["Title"] = "Usuários e Perfis"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }
<section class="saas7-hero" data-users-page><div><span class="badge">Sistema > Usuários e Perfis</span><h1>Usuários, perfis e permissões visuais</h1><p>Demonstração enterprise de cadastro, edição, inativação, reset de senha, unidade, perfil e permissões por módulo.</p></div><button class="btn btn-gold" form="UserForm">Criar usuário</button></section>
<section class="saas7-grid"><article class="saas7-card wide"><h2>Usuários cadastrados</h2><table class="saas7-table"><thead><tr><th>Usuário</th><th>Perfil</th><th>Unidade</th><th>Permissões</th><th>Status</th><th>Ações</th></tr></thead><tbody data-users-rows></tbody></table></article><article class="saas7-card"><h2>Novo usuário demo</h2><form id="UserForm" class="saas7-form" data-user-form><label class="full">Nome<input name="name" required></label><label class="full">E-mail<input name="email" type="email" required></label><label>Perfil<select name="role"><option>Administrador</option><option>Gerente</option><option>Recepção</option><option>Profissional</option><option>Financeiro</option><option>Estoque</option><option>Marketing</option><option>Totem</option><option>Consulta</option></select></label><label>Unidade<select name="branch"><option>Todas</option><option>Barbearia Elite Matriz</option><option>BarberSync Studio Umarizal</option><option>BarberSync Estética Premium</option><option>BarberSync Shopping Demo</option></select></label><div class="full saas7-list">@foreach (var p in new[]{"Dashboard","Clientes","Agenda","Comandas","Caixa","Estoque","Campanhas","Relatórios","Configurações","Totem","PublicWeb"}) { <label class="saas7-switch"><input type="checkbox" name="perm" value="@p" checked> @p</label> }</div></form></article></section>
