@{
    ViewData["Title"] = "Manual de Uso";
}

<section class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h1 class="h3 mb-2">BarberSync 2.0 — Manual rápido</h1>
            <p class="text-muted mb-4">Gestão inteligente para salões, barbearias e estética.</p>
            <ol class="mb-0">
                <li>Como acessar: entre com <strong>admin@barbersync.com</strong> / <strong>Admin@123</strong>.</li>
                <li>Cadastre clientes em <strong>Clientes</strong>.</li>
                <li>Cadastre profissionais e especialidades em <strong>Profissionais</strong>.</li>
                <li>Cadastre serviços com preço e duração em <strong>Serviços</strong>.</li>
                <li>Crie agendamentos em <strong>Agenda</strong>.</li>
                <li>Abra e finalize comandas em <strong>Comandas</strong>.</li>
                <li>Registre pagamentos em <strong>Pagamentos</strong> e acompanhe em <strong>Caixa</strong>.</li>
                <li>Controle entradas, saídas e alertas em <strong>Estoque</strong>.</li>
                <li>Use o <strong>Dashboard</strong> para visão gerencial.</li>
                <li>Configure dispositivos em <strong>Totem</strong>.</li>
                <li>Use o <strong>Site Público</strong> para captação de agendamentos.</li>
                <li>Pergunte ao <strong>Copilot</strong> para sugestões operacionais.</li>
                <li>Para demo comercial, siga o roteiro em <code>Docs/DEMO_CLIENTE_ROTEIRO.md</code>.</li>
            </ol>
        </div>
    </div>
</section>
