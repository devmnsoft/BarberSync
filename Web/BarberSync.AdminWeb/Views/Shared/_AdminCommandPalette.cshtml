<div class="admin-command-palette" id="AdminCommandPalette" hidden aria-hidden="true" role="dialog" aria-label="Command palette BarberSync">
    <div class="command-palette-card">
        <div class="command-palette-header">
            <div>
                <span class="modal-kicker">BarberSync Demo Experience 2.0</span>
                <h3>Command palette</h3>
            </div>
            <button type="button" class="modal-close" data-command-close aria-label="Fechar command palette">×</button>
        </div>
        <label class="command-search">
            <span>⌘</span>
            <input id="AdminCommandSearch" type="search" placeholder="Digite uma ação: cliente, agendamento, comanda..." autocomplete="off" />
            <kbd>Ctrl K</kbd>
        </label>
        <div class="command-list" data-command-list></div>
        <p class="command-hint">Use ↑/↓ para navegar, Enter para executar e Esc para fechar. Todas as ações usam rotas/proxies locais da demo.</p>
    </div>
</div>
<div class="admin-command-scrim" data-command-close hidden></div>
