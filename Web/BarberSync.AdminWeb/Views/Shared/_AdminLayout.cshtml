<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - BarberSync Demo Experience 3.0</title>
    <link rel="stylesheet" href="~/css/admin-design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-brand.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-onboarding.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-demo.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-tour.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <partial name="_AdminSidebar" />
        <div class="admin-main">
            <partial name="_AdminDemoBanner" />
            <partial name="_AdminTopbar" />
            <main class="admin-content">@RenderBody()</main>
        </div>
    </div>
    <partial name="_AdminToast" />
    <partial name="_AdminConfirmModal" />
    <partial name="_AdminHelpDrawer" />
    <partial name="_AdminCommandPalette" />
    <partial name="_AdminTourOverlay" />
    <script src="~/js/admin-api-client.js" asp-append-version="true"></script>
    <script src="~/js/admin-demo-store.js" asp-append-version="true"></script>
    <script src="~/js/admin-demo-mode.js" asp-append-version="true"></script>
    <script src="~/js/admin-operation-flow.js" asp-append-version="true"></script>
    <script src="~/js/admin-demo-tour.js" asp-append-version="true"></script>
    <script src="~/js/admin-toast.js" asp-append-version="true"></script>
    <script src="~/js/admin-modal.js" asp-append-version="true"></script>
    <script src="~/js/admin-forms.js" asp-append-version="true"></script>
    <script src="~/js/admin-tables.js" asp-append-version="true"></script>
    <script src="~/js/admin-shell.js" asp-append-version="true"></script>
    <script src="~/js/admin-command-palette.js" asp-append-version="true"></script>
    <script src="~/js/admin-dashboard.js" asp-append-version="true"></script>
    <script src="~/js/admin-crud.js" asp-append-version="true"></script>
    <script src="~/js/admin-filters.js" asp-append-version="true"></script>
    <script src="~/js/admin-help.js" asp-append-version="true"></script>
    <script src="~/js/admin-onboarding.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
