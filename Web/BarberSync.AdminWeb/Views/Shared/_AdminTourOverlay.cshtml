<div class="admin-tour-backdrop" data-tour-backdrop hidden>
    <div class="admin-tour-card" role="dialog" aria-live="polite" aria-modal="true" aria-labelledby="tourTitle">
        <div class="tour-progress"><span data-tour-progress-bar></span></div>
        <p class="tour-step-count" data-tour-progress>Passo 1 de 14</p>
        <h3 id="tourTitle" data-tour-title>Tour Demo</h3>
        <p data-tour-text>Conheça o fluxo comercial BarberSync.</p>
        <div class="tour-actions">
            <button type="button" class="btn btn-light" data-tour-prev>Voltar</button>
            <button type="button" class="btn btn-light" data-tour-skip>Pular</button>
            <button type="button" class="btn btn-primary" data-tour-next>Próximo</button>
        </div>
    </div>
</div>
<div class="admin-tour-highlight" data-tour-highlight hidden></div>
