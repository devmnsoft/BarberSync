@{Layout="~/Views/Shared/_KioskLayout.cshtml"; ViewData["Title"]="Avaliação";}
<section class="kiosk-step"><img class="kiosk-illustration" src="~/img/kiosk-success.svg" alt="Avaliação"/><h1>Como foi sua experiência?</h1><form id="kioskReviewForm" class="kiosk-form"><div class="kiosk-stars" role="radiogroup" aria-label="Avaliação"><button type="button" data-rating="1">★</button><button type="button" data-rating="2">★</button><button type="button" data-rating="3">★</button><button type="button" data-rating="4">★</button><button type="button" data-rating="5" class="selected">★</button></div><input type="hidden" name="rating" value="5"/><input name="comment" placeholder="Comentário opcional"/><button class="k-btn">Enviar avaliação</button></form></section>
