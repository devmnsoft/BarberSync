@{Layout="~/Views/Shared/_KioskLayout.cshtml"; ViewData["Title"]="Serviços";}
<section class="kiosk-services-screen">
    <div class="kiosk-progress"><span style="width:35%"></span></div>
    <div class="kiosk-heading">
        <div>
            <h1 data-kiosk-title>Escolha seu serviço</h1>
            <p data-kiosk-message>Bem-vindo ao Totem BarberSync. Toque em um card para continuar.</p>
        </div>
        <div class="kiosk-actions">
            <button type="button" class="btn btn-outline-light" data-kiosk-accessibility>Alto contraste</button>
            <button type="button" class="btn btn-outline-light" data-kiosk-help>Chamar atendente</button>
            <a href="/Kiosk/Index" class="btn btn-outline-danger">Cancelar</a>
            <span id='kioskDemoNotice' class='badge text-bg-warning' hidden>Modo demonstração</span>
        </div>
    </div>
    <div id='kioskServices' class='kiosk-grid'></div>
</section>
<section class="kiosk-flow-v5" data-kiosk-v5>
  <h2>Totem 5.0 • Autoatendimento completo</h2>
  <div class="kiosk-grid"><button data-kiosk-demo="service">1. Serviço</button><button data-kiosk-demo="combo">2. Combo Corte + Barba</button><button data-kiosk-demo="client">3. Cliente e teclado visual</button><button data-kiosk-demo="professional">4. Profissional</button><button data-kiosk-demo="confirm">5. Confirmação</button><button data-kiosk-demo="payment">6. PIX QR/Card/Dinheiro</button><button data-kiosk-demo="success">7. Sucesso e comanda</button><button data-kiosk-demo="review">8. Avaliação</button><button data-kiosk-print>Imprimir mock</button><button data-kiosk-restart>Reiniciar</button></div>
  <div class="kiosk-card" data-kiosk-v5-summary>Toque em um passo para simular atendimento com DeviceCode KIOSK-DEMO-001.</div>
</section>
