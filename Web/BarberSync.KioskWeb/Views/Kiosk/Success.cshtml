@{Layout="~/Views/Shared/_KioskLayout.cshtml"; ViewData["Title"]="Sucesso";}
<section class="kiosk-step success"><div class="kiosk-progress"><span style="width:100%"></span></div><img src="~/img/kiosk-success.svg" alt="Sucesso"/><h1>Atendimento confirmado!</h1><p>Atendimento registrado. A comanda foi enviada para o painel. Sua comanda demo foi gerada e o recibo visual está disponível.</p><div class="panel" data-kiosk-success-summary></div><a class="k-btn" href="/Kiosk/Summary">Ver resumo</a><a class="k-btn secondary" href="/Kiosk/Review">Avaliar experiência</a></section>

@section Scripts {<script>document.addEventListener("DOMContentLoaded",()=>{const el=document.querySelector("[data-kiosk-success-summary]");const s=JSON.parse(sessionStorage.getItem("barbersync.kiosk.summary")||"{}");if(el)el.innerHTML=`<strong>Atendimento:</strong> ${s.attendanceId||"KIOSK-DEMO"}<br><strong>Comanda:</strong> ${s.serviceOrderNumber||"TK-DEMO"}<br><strong>Pagamento:</strong> ${(s.payment&&s.payment.method)||"PIX"} aprovado`;});</script>}
