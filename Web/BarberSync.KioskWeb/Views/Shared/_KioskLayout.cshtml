<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] - BarberSync Kiosk</title>
    <link rel="stylesheet" href="~/css/kiosk-design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/kiosk-brand.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/kiosk.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/kiosk-flow.css" asp-append-version="true" />
</head>
<body>
    <header class="kiosk-header">
        <img src="~/img/logo-barbersync-white.svg" alt="BarberSync"/>
        <div class="kiosk-mode"><span>Modo demonstração</span><strong>KIOSK-DEMO-001</strong></div>
        <button type="button" class="kiosk-reset" data-kiosk-back>Voltar</button>
        <button type="button" class="kiosk-reset" data-kiosk-help>Chamar atendente</button>
        <button type="button" class="kiosk-reset" data-kiosk-accessibility>Alto contraste</button>
        <a href="/Kiosk/Services" class="kiosk-reset" data-kiosk-cancel>Cancelar</a>
    </header>
    <main class="kiosk-container kiosk-shell-grid"><section>@RenderBody()</section><aside class="kiosk-side-summary" aria-live="polite"><h3>Resumo</h3><div data-kiosk-summary-lateral>Escolha um serviço para iniciar.</div><div class="kiosk-timeout"><span data-kiosk-timeout-bar></span></div><small>Tempo visual de sessão: 60s. Toque na tela para continuar.</small></aside></main>
    <script>window.BarberSyncKiosk = { deviceCode: 'KIOSK-DEMO-001' };</script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/kiosk-flow.js" asp-append-version="true"></script>
    <script src="~/js/kiosk.js" asp-append-version="true"></script>
    <script src="~/js/kiosk-timeout.js" asp-append-version="true"></script>
</body>
</html>
