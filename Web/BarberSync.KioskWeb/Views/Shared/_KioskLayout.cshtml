<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/kiosk-brand.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/kiosk.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/kiosk-flow.css" asp-append-version="true" />
</head>
<body>
    <header class='p-3 d-flex justify-content-between'>
        <img src='~/img/logo-barbersync.svg' height='48' alt="BarberSync"/>
        <a href='/Kiosk/Index' class='btn btn-outline-light btn-lg'>Voltar</a>
    </header>
    <main class='container py-4'>@RenderBody()</main>

    <script>
        window.BarberSyncKiosk = { deviceCode: 'KIOSK-DEMO-001' };
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src='~/js/kiosk.js' asp-append-version="true"></script>
    <script src='~/js/kiosk-flow.js' asp-append-version="true"></script>
    <script src='~/js/kiosk-timeout.js' asp-append-version="true"></script>
</body>
</html>
