@{ ViewData["Title"]="BarberSync"; }
<header class="pub-header"><img src="~/img/logo-barbersync.svg" alt="BarberSync"/><nav><a href="#servicos">Serviços</a><a href="#profissionais">Profissionais</a><a href="#planos">Planos</a><a href="#faq">FAQ</a></nav></header>
<section class="hero"><h1>BarberSync SaaS para Barbearias</h1><p>Agendamento, totem, dashboard e IA em uma única plataforma enterprise.</p><a class="btn-primary" href="#agendamento">Agendar agora</a></section>
