@{ ViewData["Title"]="BarberSync SaaS"; }
<header class="pub-header"><img src="~/img/logo-barbersync.svg" alt="BarberSync"/><nav><a href="#servicos">Serviços</a><a href="#profissionais">Profissionais</a><a href="#beneficios">Benefícios</a><a href="#planos">Planos</a><a href="#faq">FAQ</a></nav><a class="btn-primary" href="/Admin">Área admin</a></header>
<section class="hero"><div><span class="eyebrow">SaaS enterprise para beleza</span><h1>Barbearias, salões e franquias com agenda, totem, mobile e IA no mesmo ecossistema.</h1><p>Uma experiência premium para vender, atender, fidelizar e medir performance em tempo real.</p><a class="btn-primary" href="#agendamento">Agendar demonstração</a></div><img src="~/img/hero-salon-premium.svg" alt="Salão premium BarberSync"/></section>
<section id="servicos" class="grid-section"><h2>Serviços em destaque</h2><p>Dados carregados via /PublicApi/services com fallback visual.</p><div id="services" class="card-grid"></div></section>
<section id="profissionais" class="grid-section"><h2>Profissionais disponíveis</h2><div id="pros" class="card-grid"></div></section>
<section id="agendamento" class="grid-section"><h2>Agendamento público</h2><form id="publicAppointment" class="panel public-form"><input name="name" placeholder="Seu nome" required/><input name="phone" placeholder="WhatsApp" required/><select name="service"><option>Corte Masculino</option><option>Corte + Barba</option></select><button class="btn-primary">Solicitar horário</button><small id="publicAppointmentResult">Integração segura via /PublicApi/appointments.</small></form></section>
<section id="beneficios" class="grid-section"><h2>Plataforma completa</h2><div class="card-grid"><article class="panel"><img src="~/img/feature-dashboard.svg" alt=""/><h3>Dashboard executivo</h3><p>KPIs, estoque, comandas e campanhas.</p></article><article class="panel"><img src="~/img/feature-kiosk.svg" alt=""/><h3>Totem operacional</h3><p>Autoatendimento com pagamento mock.</p></article><article class="panel"><img src="~/img/feature-mobile.svg" alt=""/><h3>Mobile app</h3><p>Agendamento, cashback e perfil do cliente.</p></article><article class="panel"><img src="~/img/feature-ai.svg" alt=""/><h3>Copilot IA</h3><p>Sugestões de crescimento e retenção.</p></article></div></section>
<section id="planos" class="grid-section"><h2>Planos mock</h2><div class="card-grid"><article class="panel"><h3>Starter</h3><strong>R$ 199/mês</strong><p>Agenda e landing.</p></article><article class="panel featured"><h3>Growth</h3><strong>R$ 399/mês</strong><p>Admin, totem e CRM.</p></article><article class="panel"><h3>Enterprise</h3><strong>Sob consulta</strong><p>Franquias e BI avançado.</p></article></div></section>
<section class="grid-section"><h2>Depoimentos</h2><div class="card-grid"><article class="panel">“O BarberSync organizou nossa operação em uma semana.”</article><article class="panel">“Totem e cashback aumentaram recorrência.”</article></div></section>
<section id="faq" class="grid-section"><h2>FAQ</h2><div class="panel"><strong>Implantação rápida:</strong> ambiente demo, treinamento e roteiro comercial em até 7 dias.</div></section>
<footer class="pub-footer"><img src="~/img/logo-barbersync-white.svg" alt="BarberSync"/>© BarberSync • SaaS premium para beleza</footer>
<script src="~/js/public.js" asp-append-version="true"></script>
