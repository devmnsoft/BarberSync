@{ ViewData["Title"]="BarberSync SaaS"; }
<header class="pub-header">
    <img src="~/img/logo-barbersync.svg" alt="BarberSync"/>
    <nav><a href="#porque">Por que escolher</a><a href="#solucao">Solução</a><a href="#servicos">Serviços</a><a href="#planos">Planos</a><a href="#agendamento">Solicitar demonstração</a></nav>
    <a class="btn-primary sticky-cta" href="#demo-comercial">Solicitar demonstração</a>
</header>
<section class="hero">
    <div><span class="eyebrow">SaaS enterprise para beleza, salões e franquias</span><h1>Agenda, totem, mobile, caixa, estoque e Copilot IA no mesmo ecossistema BarberSync.</h1><p>Uma landing premium demonstrável para vender, atender, fidelizar e medir performance em tempo real sem expor URLs internas da API no navegador.</p><div class="hero-actions"><a class="btn-primary" href="#agendamento">Agendar serviço</a><a class="btn-secondary" href="/Admin/Dashboard">Ver painel administrativo</a><a class="btn-secondary" href="/Kiosk/Services">Testar totem</a></div></div>
    <img src="~/img/hero-salon-premium.svg" alt="Salão premium BarberSync"/>
</section>
<section id="problemas" class="grid-section split"><div><span class="eyebrow">Problemas reais</span><h2>Operações de beleza perdem margem quando agenda, caixa, estoque e relacionamento ficam separados.</h2></div><div class="card-grid"><article class="panel">No-show sem automação de confirmação.</article><article class="panel">Estoque crítico descoberto tarde demais.</article><article class="panel">Campanhas sem leitura de retorno.</article></div></section>
<section id="solucao" class="grid-section"><h2>Solução BarberSync</h2><div class="card-grid"><article class="panel"><img src="~/img/feature-dashboard.svg" alt=""/><h3>Dashboard executivo</h3><p>KPIs, comandas, ocupação, reputação e estoque em uma visão comercial.</p></article><article class="panel"><img src="~/img/feature-kiosk.svg" alt=""/><h3>Totem ponta a ponta</h3><p>Autoatendimento com serviço, cliente, profissional, pagamento mock e avaliação.</p></article><article class="panel"><img src="~/img/feature-mobile.svg" alt=""/><h3>Mobile app</h3><p>Agendamentos, cashback, serviços e perfil com a identidade BarberSync 2.0.</p></article><article class="panel"><img src="~/img/feature-ai.svg" alt=""/><h3>Copilot IA</h3><p>Sugestões de retenção, escala, campanhas e aumento de ticket médio.</p></article><article class="panel"><img src="~/img/feature-cashier.svg" alt=""/><h3>Caixa e comandas</h3><p>Fluxo visual para abrir, pagar, fechar e demonstrar recibo.</p></article><article class="panel"><img src="~/img/feature-stock.svg" alt=""/><h3>Estoque crítico</h3><p>Barras, mínimos e entrada/saída com fallback demo seguro.</p></article></div></section>
<section id="servicos" class="grid-section"><h2>Serviços em destaque</h2><p>Dados carregados via <strong>/PublicApi/services</strong> com fallback visual local.</p><div id="services" class="card-grid skeleton-grid"><article class="panel skeleton"></article><article class="panel skeleton"></article><article class="panel skeleton"></article></div></section>
<section id="profissionais" class="grid-section"><h2>Profissionais disponíveis</h2><div id="pros" class="card-grid skeleton-grid"><article class="panel skeleton"></article><article class="panel skeleton"></article></div></section>
<section id="agendamento" class="grid-section appointment-section"><div><span class="eyebrow">Agendamento público</span><h2>Solicite um horário demonstrativo</h2><p>O browser conversa somente com <strong>/PublicApi/appointments</strong>; a URL interna da API permanece server-side.</p></div><form id="publicAppointment" class="panel public-form"><input name="name" placeholder="Seu nome" required/><input name="phone" placeholder="WhatsApp" required/><select name="service" required><option>Corte Masculino</option><option>Corte + Barba</option><option>Barba Tradicional</option></select><select name="professional" required><option>Primeiro disponível</option><option>Rafael Barber</option><option>Camila Beauty</option></select><input type="date" name="date" required/><input type="time" name="time" required/><textarea name="notes" placeholder="Observação"></textarea><button class="btn-primary" type="submit">Solicitar horário</button><p class="public-badge">Este agendamento aparecerá no painel administrativo em modo demonstração.</p><small id="publicAppointmentResult">Pronto para receber sua solicitação.</small></form></section>
<section class="grid-section commercial-band"><h2>Totem + Mobile + Dashboard + Copilot</h2><p>Uma demonstração comercial completa para barbearias premium, salões, estética e redes franqueadas.</p></section>

<section class="grid-section" id="porque"><h2>Por que escolher o BarberSync?</h2><div class="card-grid"><article class="panel"><h3>Operação unificada</h3><p>Admin, PublicWeb, Totem, Mobile, estoque, caixa e CRM no mesmo roteiro.</p></article><article class="panel"><h3>Demonstração sem fricção</h3><p>Fallback visual garante apresentação mesmo se a API estiver em modo demo.</p></article><article class="panel"><h3>Escala para franquias</h3><p>Indicadores, unidade demo, campanhas e governança para redes.</p></article></div></section>
<section class="grid-section split" id="antes-depois"><div><span class="eyebrow">Antes e depois</span><h2>Antes: planilhas, fila e no-show. Depois: jornada guiada, confirmação, comanda e fidelização.</h2></div><div class="card-grid"><article class="panel"><h3>Antes</h3><p>Agenda isolada, estoque sem alerta e cliente sem histórico.</p></article><article class="panel featured"><h3>Depois</h3><p>Cliente 360, status da agenda, recibo visual, cashback e Copilot.</p></article></div></section>
<section class="grid-section"><h2>Diferenciais</h2><div class="card-grid"><article class="panel">Totem inteligente com acessibilidade.</article><article class="panel">App para clientes com cashback e promoções.</article><article class="panel">IA para gestão com prioridades alta, média e baixa.</article><article class="panel">PublicWeb com CTA de agendamento e demonstração.</article></div></section>
<section class="grid-section"><h2>Como funciona</h2><div class="card-grid"><article class="panel"><strong>1.</strong> Cliente agenda pelo site ou totem.</article><article class="panel"><strong>2.</strong> Admin confirma, faz check-in e abre comanda.</article><article class="panel"><strong>3.</strong> Caixa registra pagamento e estoque é acompanhado.</article><article class="panel"><strong>4.</strong> Copilot sugere campanha e reativação.</article></div></section>
<section class="grid-section commercial-band"><h2>Totem inteligente + App para clientes + IA para gestão</h2><p>Autoatendimento guiado, experiência mobile com cashback e Copilot para ações comerciais.</p><div class="hero-actions"><a class="btn-primary" href="/Kiosk/Services">Testar totem</a><a class="btn-secondary" href="/Admin/Dashboard">Ver painel administrativo</a><a class="btn-primary" href="#agendamento">Solicitar demonstração</a></div></section>

<section class="grid-section split" id="resultados-esperados"><div><span class="eyebrow">Resultados esperados</span><h2>Mais conversão, menos fila e gestão com dados vivos.</h2><p>Roteiro comercial mostra PublicWeb, Admin, PDV, estoque, campanhas, Copilot e Totem em sequência.</p></div><div class="card-grid"><article class="panel"><h3>+18%</h3><p>Conversão estimada do site público.</p></article><article class="panel"><h3>-35%</h3><p>Tempo de fila com autoatendimento no totem.</p></article><article class="panel"><h3>+22%</h3><p>Recorrência com cashback e campanhas.</p></article></div></section>
<section class="grid-section" id="demo-comercial"><h2>Solicitar demonstração comercial</h2><form id="demoRequest" class="panel public-form"><input name="company" placeholder="Nome da barbearia/salão" required/><input name="contact" placeholder="Seu nome" required/><input name="whatsapp" placeholder="WhatsApp" required/><select name="size"><option>1 unidade</option><option>2 a 5 unidades</option><option>Franquia / rede</option></select><textarea name="goal" placeholder="Principal objetivo: reduzir fila, vender mais, controlar estoque..."></textarea><button class="btn-primary" type="submit">Quero ver o BarberSync</button><small id="demoRequestResult">Resposta simulada para demonstração comercial.</small></form></section>
<section id="planos" class="grid-section"><h2>Planos demonstrativos</h2><div class="card-grid"><article class="panel price-card"><h3>Starter</h3><strong>R$ 199/mês</strong><p>Agenda, landing e catálogo.</p><a href="#agendamento">Começar</a></article><article class="panel price-card featured"><h3>Growth</h3><strong>R$ 399/mês</strong><p>Admin, totem, CRM e estoque.</p><a href="#agendamento">Ver demo</a></article><article class="panel price-card"><h3>Enterprise</h3><strong>Sob consulta</strong><p>Franquias, BI e governança.</p><a href="#agendamento">Falar com especialista</a></article></div></section>
<section class="grid-section"><h2>Depoimentos</h2><div class="card-grid"><article class="panel testimonial">“O BarberSync organizou agenda, estoque e retorno de clientes em uma semana.”<strong>Barbearia Elite Demo</strong></article><article class="panel testimonial">“Totem e cashback aumentaram recorrência e reduziram fila no balcão.”<strong>Rede Premium Beauty</strong></article></div></section>
<section id="faq" class="grid-section"><h2>FAQ</h2><div class="faq-list"><details open><summary>Como funciona a implantação?</summary><p>Ambiente demo, parametrização, treinamento e roteiro comercial em até 7 dias.</p></details><details><summary>O site depende de internet para assets?</summary><p>Não. Logos e ilustrações usados nesta demonstração são locais.</p></details><details><summary>Como a integração com a API é feita?</summary><p>PublicWeb usa /PublicApi; Admin usa /AdminApi; Kiosk usa /KioskApi.</p></details></div></section>
<div id="publicToast" class="public-toast" hidden></div>
<footer class="pub-footer"><img src="~/img/logo-barbersync-white.svg" alt="BarberSync"/>© BarberSync • SaaS premium para beleza</footer>
