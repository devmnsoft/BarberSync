@{ ViewData["Title"]="BarberSync PublicWeb configurável"; }
<header class="pub-header"><img src="~/img/logo-barbersync.svg" alt="BarberSync"/><nav><a href="#servicos">Serviços</a><a href="#profissionais">Profissionais</a><a href="#promocoes">Promoções</a><a href="#agendamento">Agendar</a><a href="#demo-comercial">Demo</a></nav><a class="btn-primary sticky-cta" href="#agendamento">Solicitar demonstração</a></header>
<section class="hero"><div><span class="eyebrow">PublicWeb configurável pelo Admin</span><h1 data-public-title>Barbearia premium conectada ao BarberSync</h1><p data-public-subtitle>Agende online, ganhe cashback e experimente uma operação omnichannel com Admin, Totem e Mobile.</p><div class="hero-actions"><a class="btn-primary" href="#agendamento" data-public-cta-primary>Agendar agora</a><a class="btn-secondary" href="#demo-comercial" data-public-cta-secondary>Solicitar demonstração</a><a class="btn-secondary" href="http://localhost:8083/Kiosk/Services" target="_blank" rel="noopener">Testar Totem</a></div></div><img src="~/img/hero-salon-premium.svg" alt="Salão premium BarberSync"/></section>
<section class="grid-section commercial-band"><h2 data-public-company>BarberSync Elite</h2><p data-public-slogan>Agenda, PDV, caixa, estoque e canais em uma experiência premium.</p></section>
<section id="servicos" class="grid-section"><h2>Serviços publicados</h2><p>Carregamento via <strong>/PublicApi/services</strong> com fallback visual coerente quando a API não responder.</p><div id="services" class="card-grid skeleton-grid"><article class="panel skeleton"></article><article class="panel skeleton"></article><article class="panel skeleton"></article></div></section>
<section id="profissionais" class="grid-section"><h2>Profissionais publicados</h2><div id="pros" class="card-grid skeleton-grid"><article class="panel skeleton"></article><article class="panel skeleton"></article></div></section>
<section id="promocoes" class="grid-section"><h2>Promoções e fidelidade</h2><div class="card-grid"><article class="panel featured"><span class="public-badge">Cupom BEMVINDO15</span><h3>Combo Primeira Visita</h3><p>Corte + Barba com 15% OFF, cashback demo e comunicação omnichannel.</p></article><article class="panel"><h3>Cashback</h3><p>Clientes visualizam saldo no Mobile e podem usar no próximo atendimento.</p></article></div></section>
<section id="agendamento" class="grid-section appointment-section"><div><span class="eyebrow">Agendamento público</span><h2>Solicite um horário demonstrativo</h2><p>O browser conversa somente com <strong>/PublicApi/appointments</strong>; URLs internas permanecem server-side.</p></div><form id="publicAppointment" class="panel public-form"><input name="name" placeholder="Seu nome" required/><input name="phone" placeholder="WhatsApp" required/><select name="service" required><option>Corte Masculino</option><option>Combo Corte + Barba</option><option>Barboterapia</option></select><select name="professional" required><option>Primeiro disponível</option><option>Rafael Barber</option><option>Bruna Estética</option></select><input type="date" name="date" required/><input type="time" name="time" required/><textarea name="notes" placeholder="Observação"></textarea><button class="btn-primary" type="submit">Solicitar horário</button><small id="publicAppointmentResult">Pronto para receber sua solicitação.</small></form></section>
<section id="demo-comercial" class="grid-section commercial-band"><h2>Sistema demonstrativo BarberSync</h2><p>Roteiro comercial completo com Admin enterprise, PublicWeb, Totem, Mobile, PDV, caixa, estoque, multiunidade, auditoria, notificações e Copilot.</p><div class="hero-actions"><a class="btn-primary" href="http://localhost:8081/Admin" target="_blank" rel="noopener">Ver Admin</a><a class="btn-secondary" href="http://localhost:8083/Kiosk/Services" target="_blank" rel="noopener">Testar Totem</a><a class="btn-secondary" href="#agendamento">Solicitar demonstração</a></div></section>
<div id="publicToast" class="public-toast" hidden></div>
<script src="~/js/public.js" asp-append-version="true"></script>
