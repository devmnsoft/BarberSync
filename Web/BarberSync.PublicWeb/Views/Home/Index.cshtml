@{ ViewData["Title"]="BarberSync"; }
<header class="pub-header"><img src="~/img/logo-barbersync.svg"/><nav><a href="#servicos">Serviços</a><a href="#profissionais">Profissionais</a><a href="#faq">FAQ</a></nav></header>
<section class="hero"><h1>BarberSync 2.0</h1><p>Gestão, agendamento público, totem e copilot IA.</p><a class="btn-primary" href="#agendamento">Agendar agora</a></section>
<section id="servicos" class="grid-section"><h2>Serviços</h2><div id="services" class="card-grid"></div></section>
<section id="profissionais" class="grid-section"><h2>Profissionais</h2><div id="pros" class="card-grid"></div></section>
<section id="agendamento" class="grid-section"><h2>Agendamento público</h2><div class="panel">Formulário rápido de agendamento com fallback demo.</div></section>
<section class="grid-section"><h2>Benefícios</h2><div class="card-grid"><article class="panel">Totem inteligente</article><article class="panel">App mobile</article><article class="panel">Copilot IA</article></div></section>
<section id="faq" class="grid-section"><h2>FAQ</h2><div class="panel">Perguntas frequentes sobre o serviço.</div></section>
<footer class="pub-footer">© BarberSync</footer>
<script src="~/js/public.js" asp-append-version="true"></script>
